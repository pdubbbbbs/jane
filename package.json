{
  "name": "jane",
  "version": "1.1.0",
  "description": "Dark standalone desktop app for Agent S — cyberpunk dark theme, window state persistence, polished UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --arm64",
    "build-mac": "electron-builder --mac",
    "build-mac-arm": "electron-builder --mac --arm64",
    "build-mac-x64": "electron-builder --mac --x64",
    "build-mac-universal": "electron-builder --mac --universal",
    "build-linux": "electron-builder --linux",
    "build-win": "electron-builder --win"
  },
  "build": {
    "appId": "com.jane.agent-s",
    "productName": "Jane",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "main.js",
      "icon.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        },
        {
          "target": "zip",
          "arch": ["arm64"]
        }
      ],
      "icon": "icon.png",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "backgroundColor": "#0a0e14",
      "title": "Jane ${version}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icon.png",
      "category": "Network"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
